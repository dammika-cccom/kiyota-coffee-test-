ap-6\"><a class=\"bg-[#D4AF37] text-[#2C1810] px-14 py-5 text-[11px] font-black uppercase tracking-[0.3em] hover:bg-white transition-all shadow-2xl shadow-[#D4AF37]/20\" href=\"/shop\">Shop The Roastery</a><a class=\"border-2 border-white/20 text-white px-14 py-5 text-[11px] font-black uppercase tracking-[0.3em] hover:bg-white hover:text-[#2C1810] transition-all backdrop-blur-md\" href=\"/wholesale\">Wholesale &amp; Export</a></div></div></section><div class=\"bg-[#2C1810] py-16 border-y border-[#D4AF37]/20 relative z-20\"><div class=\"max-w-7xl mx-auto grid grid-cols-2 md:grid-cols-4 gap-12\"><div class=\"text-center space-y-3 group cursor-default\"><svg class=\"w-6 h-6 text-[#D4AF37] mx-auto opacity-40 group-hover:opacity-100 transition-all duration-500\" xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M17 8h1a4 4 0 1 1 0 8h-1\"></path><path d=\"M3 8h14v9a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4Z\"></path><path d=\"M6 2v2\"></path><path d=\"M10 2v2\"></path><path d=\"M14 2v2\"></path></svg><span class=\"text-[#FAF9F6] font-mono text-3xl font-bold block tracking-tighter\">4,500+</span><span class=\"text-[#D4AF37]/50 text-[9px] uppercase tracking-[0.4em] font-black\">Farmers Facilitated</span></div><div class=\"text-center space-y-3 group cursor-default\"><svg class=\"w-6 h-6 text-[#D4AF37] mx-auto opacity-40 group-hover:opacity-100 transition-all duration-500\" xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"23 6 13.5 15.5 8.5 10.5 1 18\"></polyline><polyline points=\"17 6 23 6 23 12\"></polyline></svg><span class=\"text-[#FAF9F6] font-mono text-3xl font-bold block tracking-tighter\">400,000+</span><span class=\"text-[#D4AF37]/50 text-[9px] uppercase tracking-[