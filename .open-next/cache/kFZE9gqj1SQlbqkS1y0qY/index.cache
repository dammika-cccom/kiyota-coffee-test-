amp;w=1200&amp;q=75 1200w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1500651230702-0e2d8a49d4ad%3Fauto%3Dformat%26fit%3Dcrop%26q%3D80%26w%3D1200&amp;w=1920&amp;q=75 1920w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1500651230702-0e2d8a49d4ad%3Fauto%3Dformat%26fit%3Dcrop%26q%3D80%26w%3D1200&amp;w=2048&amp;q=75 2048w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1500651230702-0e2d8a49d4ad%3Fauto%3Dformat%26fit%3Dcrop%26q%3D80%26w%3D1200&amp;w=3840&amp;q=75 3840w\" src=\"/_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1500651230702-0e2d8a49d4ad%3Fauto%3Dformat%26fit%3Dcrop%26q%3D80%26w%3D1200&amp;w=3840&amp;q=75\"/><div class=\"absolute inset-0 bg-gradient-to-t from-[#2C1810]/80 to-transparent\"></div><div class=\"absolute bottom-10 left-10 text-white\"><h4 class=\"text-3xl font-serif italic text-[#D4AF37]\">The Nursery Project</h4><p class=\"text-[10px] uppercase tracking-[0.4em] opacity-60\">Vertical Logistics: Matale</p></div></div><div class=\"space-y-12\"><div class=\"space-y-6\"><h5 class=\"text-[10px] font-black uppercase tracking-[0.4em] text-[#D4AF37]\">Traceability</h5><h2 class=\"text-5xl md:text-7xl font-serif italic text-[#2C1810] leading-none tracking-tighter\">Origin <br/> Ecosystem.</h2><p class=\"text-stone-500 font-light leading-loose text-justify text-lg italic\">Our strength lies in the 4,500 families we facilitate. By providing nursery seedlings and Japanese sorting technology, we ensure the highest density beans from Matale to Nuwara Eliya.</p></div><div class=\"space-y-8\"><div class=\"flex justify-between items-end border-b border-stone-100 pb-4 group\"><div><h4 class=\"text-xl font-serif italic text-[#2C1810] group-hover:text-[#D4AF37] transition-colors\">Matale Central</h4><div class=\"flex items-center gap-2 text-stone-400 mt-1\"><svg class=\"w-3 h-3\" xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-widt