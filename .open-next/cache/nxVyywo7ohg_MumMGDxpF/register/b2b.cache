1 9 11.01\"></polyline></svg> <!-- -->Preferential Wholesale Pricing (LKR/USD)</li><li class=\"flex items-center gap-3 text-sm opacity-80\"><svg class=\"w-5 h-5 text-[#D4AF37]\" xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M22 11.08V12a10 10 0 1 1-5.93-9.14\"></path><polyline points=\"22 4 12 14.01 9 11.01\"></polyline></svg> <!-- -->Global Export Documentation Support</li><li class=\"flex items-center gap-3 text-sm opacity-80\"><svg class=\"w-5 h-5 text-[#D4AF37]\" xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M22 11.08V12a10 10 0 1 1-5.93-9.14\"></path><polyline points=\"22 4 12 14.01 9 11.01\"></polyline></svg> <!-- -->Priority Access to Micro-lot Harvests</li><li class=\"flex items-center gap-3 text-sm opacity-80\"><svg class=\"w-5 h-5 text-[#D4AF37]\" xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M22 11.08V12a10 10 0 1 1-5.93-9.14\"></path><polyline points=\"22 4 12 14.01 9 11.01\"></polyline></svg> <!-- -->Japanese Roasting Quality Control</li></ul></div><div class=\"bg-white text-[#2C1810] p-10 rounded-sm shadow-2xl space-y-6 animate-in slide-in-from-bottom duration-1000\"><div class=\"space-y-2\"><h2 class=\"text-2xl font-serif italic\">Partner Application</h2><p class=\"text-xs text-stone-400 uppercase tracking-widest font-bold\">Verification required for pricing</p></div><form class=\"space-y-4\"><div class=\"grid grid-cols-2 gap-4\"><div class=\"space-y-1\"><label class=\"text-[9px] uppercase font-black text-stone-400\">First Name</label><input required=\"\" class=\"w-full border-b border-